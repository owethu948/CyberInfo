<Window x:Class="CyberInfo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberInfo – Cybersecurity Awareness Bot" Height="720" Width="1100"
        Background="#FFF0F5" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- ── Pink colour palette ─────────────────────────────── -->
        <SolidColorBrush x:Key="AccentPurple"   Color="#D63384"/>
        <!-- deep pink -->
        <SolidColorBrush x:Key="AccentCyan"     Color="#F25C8C"/>
        <!-- soft pink -->
        <SolidColorBrush x:Key="TextPrimary"    Color="#4A1A30"/>
        <SolidColorBrush x:Key="TextMuted"      Color="#A0607A"/>
        <SolidColorBrush x:Key="BgUserBubble"   Color="#FFE4EC"/>
        <!-- light pink -->
        <SolidColorBrush x:Key="BgBotBubble"    Color="#FFFFFF"/>
        <!-- white -->
        <SolidColorBrush x:Key="BorderAccent"   Color="#FFB6D9"/>
        <SolidColorBrush x:Key="SidebarBg"      Color="#FFD6E8"/>
        <SolidColorBrush x:Key="InputBg"        Color="#FFF0F5"/>
        <SolidColorBrush x:Key="QuizBg"         Color="#FFE4EC"/>

        <!-- Button style for sidebar topic items -->
        <Style x:Key="SidebarTopicButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFB6D9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style for action buttons (Scenario, Fact, etc.) -->
        <Style x:Key="SidebarActionButton" TargetType="Button" BasedOn="{StaticResource SidebarTopicButton}">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ════════════ LEFT SIDEBAR ════════════ -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBg}" Padding="12,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Topics header -->
                    <RowDefinition Height="*"/>
                    <!-- Topics list -->
                    <RowDefinition Height="Auto"/>
                    <!-- Memory panel -->
                    <RowDefinition Height="Auto"/>
                    <!-- Action buttons -->
                </Grid.RowDefinitions>

                <!-- About Header -->
                <TextBlock Grid.Row="0" Text="ℹ️  ABOUT" FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource AccentPurple}" Margin="0,0,0,8"/>

                <!-- About Description -->
                <TextBlock Grid.Row="1" TextWrapping="Wrap" FontSize="13"
                           Foreground="{StaticResource TextPrimary}" LineHeight="20"
                           Text="CyberInfo is your friendly cybersecurity awareness assistant. Learn about the latest threats and how to stay safe online. Explore topics like phishing, passwords, malware, 2FA, and more through interactive lessons and real-world scenarios."/>
                <TextBlock Grid.Row="1" TextWrapping="Wrap" FontSize="11"
                           Foreground="{StaticResource TextMuted}" LineHeight="18"
                           Margin="0,12,0,0" VerticalAlignment="Top"
                           Text="Topics available: Passwords, Phishing, Safe Browsing, Two-Factor Authentication, Malware, Social Engineering, Software Updates, and Public Wi-Fi."/>

                <!-- Memory Panel -->
                <Border Grid.Row="2" Background="#FFE4EC" CornerRadius="8"
                        Padding="10" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock FontWeight="Bold" Foreground="{StaticResource AccentPurple}"
                                   Margin="0,0,0,4">🧠  Memory</TextBlock>
                        <TextBlock x:Name="MemLastTopic" FontSize="12"
                                   Foreground="{StaticResource TextMuted}"/>
                        <TextBlock x:Name="MemInterests" FontSize="12"
                                   Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Action Buttons -->
                <StackPanel Grid.Row="3" Margin="0,16,0,0">
                    <Button Content="⚠️  SCENARIO" Style="{StaticResource SidebarActionButton}"
                            Click="ScenarioButton_Click"/>
                    <Button Content="📊  FACT"     Style="{StaticResource SidebarActionButton}"
                            Click="FactButton_Click"/>
                    <Button Content="💡  TIP"      Style="{StaticResource SidebarActionButton}"
                            Click="TipButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ════════════ MAIN CHAT AREA ════════════ -->
        <Grid Grid.Column="1" Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- User badge + sentiment bar -->
                <RowDefinition Height="*"/>
                <!-- Chat scroll -->
                <RowDefinition Height="Auto"/>
                <!-- Quiz panel (overlaid) -->
                <RowDefinition Height="Auto"/>
                <!-- Input area -->
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Background="{StaticResource AccentPurple}" Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="CyberInfo" FontSize="18" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                        <TextBlock Text="  |  " Foreground="#FFB6D9" VerticalAlignment="Center"
                                   FontSize="14"/>
                        <TextBlock x:Name="UserBadge" Text="Welcome!" FontSize="14"
                                   Foreground="#FFE4EC" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Sentiment bar -->
                    <Border x:Name="SentimentBar" Grid.Column="1" Background="#FFE4EC"
                            CornerRadius="6" Padding="8,4" Visibility="Collapsed"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="SentimentLabel" FontSize="13"
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="SentimentEmoji" FontSize="14"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Chat scroll viewer -->
            <ScrollViewer x:Name="ChatScroll" Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          Background="#FFF0F5" Padding="12">
                <StackPanel x:Name="ChatPanel"/>
            </ScrollViewer>

            <!-- Typing indicator -->
            <Border x:Name="TypingRow" Grid.Row="1" VerticalAlignment="Bottom"
                    Background="#FFD6E8" Padding="10" CornerRadius="8"
                    Margin="16,0" Visibility="Collapsed">
                <TextBlock Text="CyberInfo is typing..." FontStyle="Italic"
                           Foreground="{StaticResource TextMuted}" FontSize="13"/>
            </Border>

            <!-- Quiz panel (appears above input) -->
            <Border x:Name="QuizPanel" Grid.Row="2" Background="{StaticResource QuizBg}"
                    CornerRadius="10" Padding="16" Margin="12,8"
                    Visibility="Collapsed" BorderBrush="{StaticResource AccentPurple}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="SCENARIO CHALLENGE" FontWeight="Bold" FontSize="15"
                               Foreground="{StaticResource AccentPurple}" Margin="0,0,0,6"/>
                    <TextBlock x:Name="QuizDesc" Grid.Row="0" TextWrapping="Wrap"
                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8"/>

                    <!-- Options -->
                    <ItemsControl x:Name="QuizOptions" Grid.Row="1">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Label}" Tag="{Binding Idx}"
                                        Click="QuizOption_Click"
                                        Background="{StaticResource BgBotBubble}"
                                        Foreground="{StaticResource TextPrimary}"
                                        BorderBrush="{StaticResource BorderAccent}"
                                        BorderThickness="1" Margin="0,4"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Padding="10,6">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Cancel button -->
                    <Button Grid.Row="2" Content="Cancel Quiz" Click="CancelQuiz_Click"
                            Background="{StaticResource AccentPurple}" Foreground="White"
                            BorderThickness="0" Padding="12,6" Margin="0,8,0,0"
                            HorizontalAlignment="Right">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>

            <!-- Input area -->
            <Border Grid.Row="3" Background="{StaticResource InputBg}" Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Input box with placeholder overlay -->
                    <Grid Grid.Column="0" Margin="0,0,8,0">
                        <TextBox x:Name="InputBox"
                                 Background="White"
                                 BorderBrush="{StaticResource AccentPurple}"
                                 BorderThickness="1"
                                 Padding="10,8"
                                 FontSize="14"
                                 Foreground="{StaticResource TextPrimary}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="False"
                                 KeyDown="InputBox_KeyDown"
                                 TextChanged="InputBox_TextChanged"/>
                        <TextBlock x:Name="Placeholder"
                                   Text="Type a topic name, number or command..."
                                   IsHitTestVisible="False"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="14"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <Button x:Name="SendBtn" Grid.Column="1"
                            Content="SEND" IsEnabled="False"
                            Background="{StaticResource AccentPurple}"
                            Foreground="White"
                            BorderThickness="0"
                            Padding="16,8"
                            FontWeight="SemiBold"
                            Click="SendButton_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>